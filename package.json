{
  "name": "mineco",
  "version": "0.2.0",
  "private": true,
  "description": "coding agent",
  "packageManager": "pnpm@10.29.3",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=25",
    "pnpm": "10.29.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "turbo": "^2.9.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "dev": "turbo run dev --filter=@mineco/core --filter=@mineco/app",
    "dev:app": "turbo run dev --filter=@mineco/app",
    "dev:core": "turbo run dev --filter=@mineco/core",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --fix ."
  }
}
