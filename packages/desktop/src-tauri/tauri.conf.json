{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "mineco",
  "version": "0.2.0",
  "identifier": "com.hiarias.mineco",
  "build": {
    "frontendDist": "../../app/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @mineco/app dev",
    "beforeBuildCommand": "pnpm --filter @mineco/app build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* ws://localhost:*; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/mineco-core"],
    "createUpdaterArtifacts": true
  }
}
