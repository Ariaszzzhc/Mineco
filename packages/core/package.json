{
  "name": "@mineco/core",
  "version": "0.2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc -p .",
    "start": "node dist/index.js",
    "build:sea": "tsx scripts/build-sea.ts",
    "create:sea": "tsx scripts/create-sea.ts",
    "sea": "pnpm build:sea && pnpm create:sea"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "@logtape/hono": "^2.0.5",
    "@logtape/logtape": "^2.0.5",
    "@mineco/agent": "workspace:*",
    "@mineco/provider": "workspace:*",
    "hono": "^4.12.9",
    "kysely": "^0.28.14",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "postject": "1.0.0-alpha.6",
    "tsx": "^4.21.0"
  }
}
